{
    "symbol": "BTC/USDT",
    "timeframe": "1h",
    "trading_mode": "future", 
    "leverage": 10,
    "exchange_mode": "paper",
    "BINANCE_API_KEY": "",
    "BINANCE_API_SECRET": "",
    "BINANCE_TESTNET_API_KEY": "",
    "BINANCE_TESTNET_API_SECRET": "",
    "historical_years": 3,
    "window": 120,
    "train_split": 0.8,
    "fast_fetch_limit": 200,
    "output_dir": "./data",
    "state_dim": 11,
    "lstm_units_1": 128,
    "lstm_units_2": 64,
    "attention_heads": 8,
    "attention_key_dim": 64,
    "dropout_rate": 0.2,
    "learning_rate": 0.001,
    "epochs": 50,
    "batch_size": 32,
    "early_stop_patience": 15,
    "embedding_dim": 16,
    "aux_horizons": [1, 4, 12, 24],
    "envelope_horizon": 12,
    "optuna_enabled": false,
    "optuna_trials": 15,
    "optuna_epochs": 10,
    "ensemble_n_estimators": 300,
    "ensemble_max_depth": 6,
    "ensemble_learning_rate": 0.05,
    "ensemble_subsample": 0.8,
    "ensemble_colsample": 0.8,
    "ensemble_early_stop": 20,
    "enable_ppo": true,
    "rl_n_episodes": 200,
    "rl_ppo_epochs": 10,
    "rl_gamma": 0.99,
    "rl_clip_epsilon": 0.2,
    "rl_entropy_coeff": 0.01,
    "ppo_actions": {
        "buy_levels": [0.10, 0.30, 0.50],
        "sell_levels": [0.10, 0.30, 0.50]
    },
    "gmm_components": 4,
    "regime_map_path": "models/regime_label_map.json",
    "regime_features": [
        "amihud_illiq",
        "efficiency_ratio_20",
        "hurst_exp",
        "wavelet_hf_ratio",
        "natr",
        "vpin",
        "ou_half_life"
    ],
    "initial_capital": 1000,
    "fee_rate": 0.004,
    "slippage": 0.0005,
    "max_risk_per_trade": 0.02,
    "max_position_pct": 0.5,
    "drawdown_penalty": 2.0,
    "stop_loss_pct": 0.0015,
    "take_profit_pct": 0.003,
    "live_paper_mode": true,
    "live_loop_interval": 60,
    "save_json": true,
    "redis_host": "localhost",
    "redis_port": 6379,
    "redis_db": 0,
    "redis_channel": null,
    "redis_reconnect_cooldown": 10.0,
    "model_save_path": "models/lstm_model.keras",
    "scaler_save_path": "models/scaler.pkl",
    "features_path": "models/final_features.json",
    "target_col": "target"
}
